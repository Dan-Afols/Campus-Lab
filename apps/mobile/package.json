{
  "name": "@campus-lab/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:prebuild": "expo prebuild -p android",
    "android:apk:debug": "cd android && gradlew.bat assembleDebug",
    "android:apk:release": "cd android && gradlew.bat assembleRelease",
    "android:build:local": "npm run android:prebuild && npm run android:apk:release",
    "android:build:local:script": "powershell -ExecutionPolicy Bypass -File ../../scripts/build-android-local.ps1",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "build:web": "expo export --platform web"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/drawer": "^6.7.2",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@reduxjs/toolkit": "^2.5.0",
    "axios": "^1.7.9",
    "expo": "^52.0.11",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.3",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "^5.7.2"
  }
}
