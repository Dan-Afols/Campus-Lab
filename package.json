{
  "name": "campus-lab",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace services/api run dev",
    "setup:postgres": "powershell -ExecutionPolicy Bypass -File ./scripts/install-postgres.ps1 -InstallIfMissing",
    "setup:redis": "powershell -ExecutionPolicy Bypass -File ./scripts/install-redis.ps1 -InstallIfMissing",
    "setup:env:local": "powershell -ExecutionPolicy Bypass -File ./scripts/configure-local-env.ps1",
    "start:local": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-stack.ps1",
    "start:local:reseed": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-stack.ps1 -ReseedData",
    "start:local:install": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-stack.ps1 -InstallServices",
    "start:local:demo": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-stack.ps1 -InstallServices -DemoAuth",
    "start:local:ngrok": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-stack.ps1 -WithNgrok",
    "start:local:ngrok:fixed": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-stack.ps1 -WithNgrok -NgrokUrl https://doozy-uncut-erupt.ngrok-free.dev",
    "start:local:web": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-stack.ps1 -WithWeb",
    "start:local:web:ngrok": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-stack.ps1 -WithWeb",
    "start:local:pwa": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-stack.ps1 -WithWeb",
    "start:local:pwa:ngrok": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-stack.ps1 -WithWeb",
    "start:local:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-stack.ps1 -InstallServices -RunSmoke",
    "smoke:local": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-local.ps1",
    "build:android:local": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android-local.ps1",
    "build:android:local:debug": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android-local.ps1 -Debug",
    "prepare:android:offline": "powershell -ExecutionPolicy Bypass -File ./scripts/prepare-android-offline-cache.ps1",
    "prepare:android:offline:fast": "powershell -ExecutionPolicy Bypass -File ./scripts/prepare-android-offline-cache.ps1 -SkipNpmInstall",
    "build:android:offline": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android-offline.ps1",
    "build:android:offline:debug": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android-offline.ps1 -Debug",
    "mobile:api:emulator": "powershell -ExecutionPolicy Bypass -File ./scripts/set-mobile-api.ps1",
    "mobile:api:lan": "powershell -ExecutionPolicy Bypass -File ./scripts/set-mobile-api.ps1 -UseLanIp",
    "web:api:local": "powershell -ExecutionPolicy Bypass -File ./scripts/set-web-api.ps1",
    "web:api:lan": "powershell -ExecutionPolicy Bypass -File ./scripts/set-web-api.ps1 -UseLanIp",
    "web:api:ngrok": "powershell -ExecutionPolicy Bypass -File ./scripts/set-web-api.ps1 -UseNgrok -NgrokUrl https://doozy-uncut-erupt.ngrok-free.app",
    "dev:mobile": "npm --workspace apps/mobile run start",
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "preview:web": "npm --workspace apps/web run preview",
    "dev:ai": "cd services/ai-server && python -m uvicorn app.main:app --host 0.0.0.0 --port 8001",
    "build": "npm --workspace services/api run build && npm --workspace apps/mobile run typecheck",
    "seed": "npm --workspace services/api run seed",
    "typecheck": "npm --workspace services/api run typecheck && npm --workspace apps/mobile run typecheck",
    "smoke": "npm --workspace services/api run smoke",
    "test:api": "vitest run --config vitest.config.ts services/api/tests/integration",
    "test:e2e:pwa": "playwright test --config playwright.config.ts tests/e2e/full-flow.spec.ts",
    "test:e2e:admin": "playwright test --config playwright.config.ts tests/e2e/admin-flow.spec.ts",
    "test:ngrok": "vitest run --config vitest.config.ts tests/ngrok",
    "test:realtime": "vitest run --config vitest.config.ts tests/realtime",
    "test:all": "npm run test:api && npm run test:e2e:pwa && npm run test:e2e:admin && npm run test:ngrok && npm run test:realtime",
    "test:stack": "bash scripts/check-stack.sh && npm run test:all"
  }
}
